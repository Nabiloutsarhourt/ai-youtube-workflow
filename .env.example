# ==========================================
# AI YouTube Workflow - Environment Variables
# ==========================================
# Copy this file to '.env' and fill in your actual credentials.
# Note: For Vercel/GitHub Actions, these should be added to their respective Secrets/Environment settings.

# 1. Gemini AI Settings (For prompting and metadata)
# Get from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# 2. YouTube Data API v3 (For uploading videos)
# This should be the raw JSON string of your authorized OAuth2 user credentials (including refresh_token)
YOUTUBE_CLIENT_SECRET={"installed":{"client_id":"...","client_secret":"...","refresh_token":"..."}}

# 3. Google Sheets API (For logging executions)
# This should be the raw JSON string of your Google Cloud Service Account credentials
GOOGLE_SHEETS_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"..."}

# 4. Video Generation API Settings
# Replace with your actual Video API Key (Runway, Pika, etc.)
VIDEO_API_KEY=your_video_generation_api_key

# 5. Application Settings (Optional Overrides)
YOUTUBE_PLAYLIST_ID=
YOUTUBE_CATEGORY_ID=27
SPREADSHEET_ID=your_google_sheet_id_from_url
SHEET_NAME=Logs
VIDEO_DURATION=10
VIDEO_RESOLUTION=1080p
